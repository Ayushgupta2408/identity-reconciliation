// Prisma schema for the Identity Reconciliation service.
// Provider defaults to Postgres (used in docker-compose) but SQLite works
// fine for quick local testing — just change `provider` and `DATABASE_URL`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LinkPrecedence {
  primary
  secondary
}

model Contact {
  id             Int            @id @default(autoincrement())
  phoneNumber    String?
  email          String?
  linkedId       Int?
  linkPrecedence LinkPrecedence @default(primary)

  // Self-relation: every secondary contact points to the primary
  // contact that "owns" the identity cluster.
  linkedContact Contact?  @relation("ContactToContact", fields: [linkedId], references: [id])
  secondaries   Contact[] @relation("ContactToContact")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Speeds up the core lookup query: WHERE email = ? OR phoneNumber = ?
  @@index([email])
  @@index([phoneNumber])
  @@index([linkedId])
}
