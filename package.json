{
  "name": "identity-reconciliation",
  "version": "1.0.0",
  "description": "Bitespeed-style Identity Reconciliation service for Zamazon.com - consolidates customer contacts across multiple orders using different emails/phone numbers.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "identity-reconciliation",
    "bitespeed",
    "express",
    "prisma"
  ],
  "author": "Ayush Kumar Gupta",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0"
  }
}
